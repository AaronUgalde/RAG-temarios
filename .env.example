# =============================================================================
# VARIABLES DE ENTORNO - EJEMPLO DE CONFIGURACIÓN
# =============================================================================
# 1. Copie este archivo y renómbrelo a ".env"
# 2. Reemplace los valores de ejemplo con sus credenciales reales
# 3. NUNCA suba el archivo ".env" a un repositorio de código (está en .gitignore)

# --- Clave de API de OpenRouter ---
# Obtenga su clave en: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Modelo a utilizar a través de OpenRouter ---
# OpenRouter da acceso a cientos de modelos con un mismo formato.
# Ejemplos de modelos disponibles:
#   anthropic/claude-3-haiku          (rápido y económico)
#   anthropic/claude-3.5-sonnet       (excelente calidad)
#   google/gemini-flash-1.5           (muy rápido)
#   openai/gpt-4o-mini                (equilibrado)
#   meta-llama/llama-3.1-8b-instruct  (open source, gratuito con límites)
# Consulte todos los modelos en: https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-3-haiku

# --- Configuración del motor RAG ---
# Número de fragmentos de texto a recuperar para cada consulta
RAG_TOP_K=5

# Tamaño de cada fragmento de texto en caracteres
CHUNK_SIZE=1000

# Superposición entre fragmentos para mantener contexto
CHUNK_OVERLAP=200
